debug_*.json
debug_*.py
debug_image.jpg
res.json

# Entorno de trabajo local y editores
.vscode/
.idea/
*.swp

# Ignorar PDFs (Ej. facturas que entran por flujo, para no subir datos sensibles),
# pero conservar la carpeta base si existe:
facturas_tipos/*.pdf
